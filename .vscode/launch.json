{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Root",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd"
    },
    {
      "name": "Version",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd",
      "args": ["version"]
    },
    {
      "name": "Init",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd",
      "args": ["init", "--config", "aaa.yaml"]
    }
  ]
}
